# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: Required for Telegram traceback alerting.
# Obtain this from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=""

# TELEGRAM_CHAT_ID: Required for Telegram traceback alerting.
# Obtain this by messaging @userinfobot or similar on Telegram.
TELEGRAM_CHAT_ID=""

# DATABASE_URL: For local PostgreSQL integration.
# Example: postgres://hb_user:homebrainpass@localhost:5432/home_brain
DATABASE_URL="postgres://hb_user:homebrainpass@localhost:5432/home_brain"

# SESSION_SECRET: Secret key for session cookies.
SESSION_SECRET="a-very-secret-key-for-local-home-brain"
